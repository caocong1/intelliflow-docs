      "density": "low",
      "background": {
        "fill": "#0D0D0D"
      },
      "elements": [
        {
          "id": "bg_surface_right",
          "type": "shape",
          "shape": "rect",
          "x": 1100,
          "y": 0,
          "w": 500,
          "h": 900,
          "z": 0,
          "fill": "#141414",
          "stroke": "#00000000",
          "strokeWidth": 0,
          "radius": 0
        },
        {
          "id": "accent_line_top",
          "type": "shape",
          "shape": "rect",
          "x": 160,
          "y": 0,
          "w": 6,
          "h": 160,
          "z": 10,
          "fill": "{palette.primary}",
          "stroke": "#00000000",
          "strokeWidth": 0,
          "radius": 0
