{
  "name": "@intelliflow/root",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "concurrently \"bun run --filter @intelliflow/backend dev\" \"bun run --filter @intelliflow/frontend dev\"",
    "dev:backend": "bun run --filter @intelliflow/backend dev",
    "dev:frontend": "bun run --filter @intelliflow/frontend dev",
    "test:ppt-agent:svg": "bun run --filter @intelliflow/backend test:ppt-agent:svg",
    "test:ppt-agent:svg:hash": "bun run --filter @intelliflow/backend test:ppt-agent:svg:hash",
    "test:ppt-agent:svg:hash:check": "bun run --filter @intelliflow/backend test:ppt-agent:svg:hash:check",
    "test:ppt-agent:svg:gate": "bun run --filter @intelliflow/backend test:ppt-agent:svg:gate",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "vitest": "^4.1.2"
  }
}
