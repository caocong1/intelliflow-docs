          "paragraphs": [
            {
              "align": "left",
              "valign": "mid",
              "runs": [
                {
                  "text": "摘自《无线网络建设全流程指南》",
                  "font": "body",
                  "size": 16,
                  "color": "{palette.muted}",
                  "bold": false,
                  "tracking": 0
