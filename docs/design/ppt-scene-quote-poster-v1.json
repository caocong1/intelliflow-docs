{
  "version": "ppt_scene/v1",
  "meta": {
    "title": "核心观点海报",
    "subject": "无线网络建设全流程指南",
    "language": "zh-CN",
    "canvas": {
      "width": 1600,
      "height": 900,
      "unit": "canvas"
    }
  },
  "theme": {
    "palette": {
      "bg": "#0D0D0D",
      "surface": "#1A1A1A",
      "text": "#FFFFFF",
      "muted": "#666666",
      "primary": "#E63946",
      "secondary": "#F4A261",
      "accent": "#457B9D",
      "success": "#2A9D8F",
      "warning": "#E9C46A",
      "border": "#333333"
    },
    "fonts": {
      "display": "Alibaba PuHuiTi 3.0 95 ExtraBold",
